{
  "name": "edit-in-place",
  "description": "SafeFleet edit-in-place",
  "version": "0.0.0-development",
    "homepage": "https://github.com/safe-fleet/edit-in-place#readme",
   "repository": {
    "type": "git",
    "url": "git+https://github.com/safe-fleet/edit-in-place.git"
  },
  "bugs": {
    "url": "https://safefleet.atlassian.net/browse"
  },
  "author": {
    "name": "Gérôme Grignon",
    "email": "gerome.grignon.lp2@gmail.com",
    "url": "https://github.com/geromegrignon"
  },
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "echo 'Work around because the tests are not working'",
    "lint": "ng lint",
    "contributors:add": "all-contributors add",
    "hooks:pre-commit": "node hooks/pre-commit.js",
    "commit": "git-cz",
    "build:lib": "ng build @ngneat/edit-in-place && npm run copy",
    "test:lib": "ng test @ngneat/edit-in-place",
    "release": "cd projects/ngneat/edit-in-place && standard-version --infile ../../../CHANGELOG.md",
    "copy": "cp -r README.md dist/edit-in-place",
    "test:lib:headless": "cross-env CI=true npm run test:lib",
    "prettier:check": "prettier --check \"**\"",
    "prettier": "prettier --write \"**\"",
    "pack:lib": "cd dist/edit-in-place && npm pack",
    "package:lib": "npm run build:lib && npm run pack:lib"
  },
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^19.2.14",
    "@angular/localize": "^19.2.14",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-browser-dynamic": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@ng-bootstrap/ng-bootstrap": "^18.0.0",
    "@ngneat/lib": "^3.0.0",
    "bootstrap": "^5.3.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.3.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.5",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.14",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-angular": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@ngneat/spectator": "latest",
    "@types/jasmine": "~5.1.4",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^16.11.11",
    "all-contributors-cli": "^6.20.0",
    "angular-cli-ghpages": "^1.0.0",
    "codelyzer": "^6.0.2",
    "cross-env": "^7.0.3",
    "git-cz": "^4.8.0",
    "husky": "^7.0.4",
    "jasmine-core": "~5.1.1",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lint-staged": "^12.1.2",
    "ng-packagr": "^20.0.1",
    "prettier": "^2.5.0",
    "standard-version": "^9.3.2",
    "ts-node": "~10.4.0",
    "tslint": "~6.1.0",
    "typescript": "~5.5.4"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,json,css,scss,ts,html,component.html}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -e $GIT_PARAMS",
      "pre-commit": "npm run hooks:pre-commit && lint-staged"
    }
  }
}
